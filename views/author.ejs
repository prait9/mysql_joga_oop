<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= AuthorName %></title>
</head>
<body>
  <h1><%= AuthorName %></h1>

  <% if (articles.length === 0) { %>
    <p>No articles found.</p>
  <% } else { %>
    <ul>
      <% articles.forEach(article => { %>
        <li>
          <h2><%= article.name %></h2>
          <p><%= article.body %></p>
        </li>
      <% }) %>
    </ul>
  <% } %>
</body>
</html>
